<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Venra Bank | Send Money</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #4f46e5; --primary-hover: #4338ca; --bg-color: #f8fafc; --surface: #ffffff; --text-main: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --btc: #F7931A; --eth: #627EEA; --danger: #ef4444; --font: 'Inter', sans-serif; }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font); }
    body { background-color: var(--bg-color); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; }

    /* DARK SIDEBAR STYLES */
    .mobile-header { display: none; padding: 16px 20px; background: #0f172a; color: white; align-items: center; justify-content: space-between; }
    .mobile-header img { height: 35px; object-fit: contain; }
    .menu-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: white; }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); z-index: 99; backdrop-filter: blur(2px); }

    .sidebar { width: 260px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; display: flex; flex-direction: column; padding: 24px 20px; z-index: 100; box-shadow: 4px 0 15px rgba(0,0,0,0.05); }
    .brand { display: flex; align-items: center; justify-content: center; margin-bottom: 40px; padding: 0 10px; }
    .brand img { height: 75px; object-fit: contain; } 
    
    .nav-menu { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
    .nav-link.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3); }
    
    .user-profile { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary), #818cf8); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .user-info { display: flex; flex-direction: column; }
    .user-info span { font-size: 13px; font-weight: 700; color: white; }
    .user-info small { font-size: 11px; color: #94a3b8; }

    /* PAGE SPECIFIC STYLES */
    .main-content { flex: 1; overflow-y: auto; padding: 40px 60px; display: flex; flex-direction: column; align-items: center; }
    .topbar { width: 100%; max-width: 600px; margin-bottom: 30px; }
    .topbar h1 { font-size: 28px; font-weight: 800; letter-spacing: -1px; }

    .card { background: var(--surface); border-radius: 24px; padding: 32px; border: 1px solid var(--border); box-shadow: 0 4px 20px rgba(0,0,0,0.02); width: 100%; max-width: 600px; }
    
    .suspend-alert { background: #fee2e2; color: #991b1b; padding: 16px; border-radius: 12px; margin-bottom: 24px; text-align: center; font-size: 14px; font-weight: 600; border: 1px solid #fca5a5; }
    .pending-alert { background: #fefce8; color: #854d0e; padding: 16px; border-radius: 12px; margin-bottom: 24px; text-align: center; font-size: 14px; font-weight: 600; border: 1px solid #fde047; }
    .error-alert { background: #fee2e2; color: #991b1b; padding: 16px; border-radius: 12px; margin-bottom: 24px; text-align: center; font-size: 14px; font-weight: 600; border: 1px solid #fca5a5; }

    .tabs { display: flex; background: #f1f5f9; border-radius: 12px; padding: 4px; margin-bottom: 30px; gap: 4px;}
    .tab { flex: 1; text-align: center; padding: 12px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; color: var(--text-muted); transition: all 0.2s; }
    .tab.active[data-currency="eur"] { background: var(--surface); color: var(--primary); box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .tab.active[data-currency="btc"] { background: var(--btc); color: white; box-shadow: 0 2px 8px rgba(247, 147, 26, 0.3); }
    .tab.active[data-currency="eth"] { background: var(--eth); color: white; box-shadow: 0 2px 8px rgba(98, 126, 234, 0.3); }

    .amount-wrapper { position: relative; margin-bottom: 30px; }
    .amount-input { width: 100%; font-size: 48px; font-weight: 800; color: var(--text-main); border: none; outline: none; background: transparent; padding: 10px 0; border-bottom: 2px solid var(--border); transition: border-color 0.2s; text-align: center; }
    .amount-input:focus { border-color: var(--primary); }
    .amount-input::placeholder { color: #cbd5e1; }
    .currency-symbol { position: absolute; left: 0; top: 50%; transform: translateY(-50%); font-size: 32px; font-weight: 700; color: var(--text-muted); pointer-events: none; }
    .available-balance { text-align: center; font-size: 13px; color: var(--text-muted); margin-top: 8px; font-weight: 600; }
    .tier-limit { text-align: center; font-size: 12px; color: var(--primary); margin-top: 4px; font-weight: 700; text-transform: uppercase; }

    .input-group { margin-bottom: 20px; }
    .input-group label { display: block; font-size: 13px; font-weight: 600; color: var(--text-main); margin-bottom: 8px; }
    .input-group input { width: 100%; padding: 16px; border: 1px solid var(--border); border-radius: 12px; font-size: 15px; font-family: var(--font); background: #f8fafc; transition: all 0.2s; outline: none; }
    .input-group input:focus { border-color: var(--primary); background: #ffffff; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }

    .btn-submit { width: 100%; padding: 16px; background: var(--primary); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.2s; margin-top: 10px; }
    .btn-submit:hover:not(:disabled) { background: var(--primary-hover); transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3); }
    .btn-submit.btc-mode:not(:disabled) { background: var(--btc); box-shadow: 0 10px 15px -3px rgba(247, 147, 26, 0.3); }
    .btn-submit.eth-mode:not(:disabled) { background: var(--eth); box-shadow: 0 10px 15px -3px rgba(98, 126, 234, 0.3); }

    /* LOADING OVERLAY CSS */
    .loading-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.95); z-index: 9999; display: none; flex-direction: column; align-items: center; justify-content: center; color: white; backdrop-filter: blur(5px); }
    .loading-overlay.active { display: flex; animation: fadeIn 0.3s ease; }
    .spinner { width: 60px; height: 60px; border: 4px solid rgba(255,255,255,0.1); border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 24px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-text { font-size: 20px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.5px; }
    .loading-subtext { font-size: 14px; color: #94a3b8; font-family: monospace; }

    @media (max-width: 900px) {
      body { flex-direction: column; }
      .mobile-header { display: flex; }
      .sidebar { position: fixed; left: -100%; top: 0; bottom: 0; transition: left 0.3s ease; width: 280px; }
      .sidebar.open { left: 0; }
      .sidebar-overlay.open { display: block; }
      .main-content { padding: 20px; flex: 1; align-items: stretch; }
      .card { padding: 24px; max-width: 100%; }
      .amount-input { font-size: 36px; }
    }
  </style>
</head>
<body>

  <div class="loading-overlay" id="loadingOverlay">
    <div class="spinner" id="dynamicSpinner"></div>
    <div class="loading-text">Processing Request</div>
    <div class="loading-subtext" id="loadingSubtext">Analyzing transaction details...</div>
  </div>

  <div class="mobile-header">
    <div style="display: flex; align-items: center; gap: 10px;">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
  </div>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

  <aside class="sidebar">
    <div class="brand">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <nav class="nav-menu">
      <a href="/dashboard" class="nav-link">Home</a>
      <a href="/send" class="nav-link active">Send Money</a>
      <a href="/receive" class="nav-link">Receive Money</a>
      <a href="/transfers" class="nav-link">Transactions</a>
      <a href="/hisa" class="nav-link">Savings Account</a>
      <a href="/account" class="nav-link">Account Details</a>
      <a href="/support" class="nav-link">Support Hub</a>
      <a href="/profile" class="nav-link">Settings</a>
    </nav>
    
    <div style="margin-top: auto;">
      <div class="user-profile">
        <div class="avatar"><%= username.charAt(0).toUpperCase() %></div>
        <div class="user-info"><span>@<%= username %></span><small><%= account.tier || 'Basic' %> Plan</small></div>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="nav-link" style="width: 100%; background: transparent; border: none; cursor: pointer; color: #f87171; font-family: var(--font);">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-right: 12px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Log Out
        </button>
      </form>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar"><h1>Transfer Funds</h1></div>

    <div class="card">
      
      <% if (error) { %>
        <div class="error-alert">
          ⛔ <%= error %>
        </div>
      <% } %>

      <% if (userStatus === 'SUSPENDED') { %>
        <div class="suspend-alert">
          ⚠️ Your account is currently under review. Outgoing transfers have been disabled. Please contact Compliance.
        </div>
      <% } else if (userStatus === 'PENDING') { %>
        <div class="pending-alert">
          ⏳ Your account is pending verification. Outgoing transfers will be unlocked upon approval.
        </div>
      <% } %>

      <form method="post" action="/send" id="sendForm">
        <input type="hidden" name="currency_type" id="currency_type_input" value="eur">

        <div class="tabs">
          <div class="tab active" data-currency="eur" onclick="switchCurrency('eur')">Euro (EUR)</div>
          <% if (account.btc_status === 'ACTIVE') { %>
            <div class="tab" data-currency="btc" onclick="switchCurrency('btc')">Bitcoin (BTC)</div>
          <% } %>
          <% if (account.eth_status === 'ACTIVE') { %>
            <div class="tab" data-currency="eth" onclick="switchCurrency('eth')">Ethereum (ETH)</div>
          <% } %>
        </div>

        <div class="amount-wrapper">
          <span class="currency-symbol" id="currency-sym">€</span>
          <input type="number" step="any" name="amount" class="amount-input" placeholder="0.00" required <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'disabled' : '' %>>
          <div class="available-balance" id="balance-display">Available: €<%= fiatBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) %></div>
          <div class="tier-limit" id="limit-display"><%= account.account_tier || 'Basic' %> Tier Daily Limit: €<%= (account.daily_limit || 10000).toLocaleString() %></div>
        </div>

        <div id="eur-fields">
          <div class="input-group"><label>Recipient Full Name</label><input type="text" name="recipient_name" placeholder="e.g. John Doe" required <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'disabled' : '' %>></div>
          <div class="input-group"><label>IBAN</label><input type="text" name="iban" placeholder="EU89 3704 0044..." style="letter-spacing: 1px;" required <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'disabled' : '' %>></div>
          <div class="input-group"><label>BIC / SWIFT Code (Optional)</label><input type="text" name="swift" placeholder="Bank Identifier Code" style="letter-spacing: 1px;" <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'disabled' : '' %>></div>
        </div>

        <div id="crypto-fields" style="display: none;">
          <div class="input-group">
            <label id="crypto-label">Wallet Address</label>
            <input type="text" name="crypto_address" placeholder="Address..." style="font-family: monospace;" <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'disabled' : '' %>>
          </div>
        </div>

        <button type="submit" class="btn-submit" id="submit-btn" <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'disabled style="opacity:0.5; cursor:not-allowed;"' : '' %>>
          <%= userStatus === 'SUSPENDED' || userStatus === 'PENDING' ? 'Transfers Disabled' : 'Continue' %>
        </button>
      </form>
    </div>
  </main>

  <script>
    const fiatBal = <%= fiatBalance %>;
    const btcBal = <%= btcBalance %>;
    const ethBal = <%= ethBalance %>;
    // FIXED: Bulletproof Fallbacks in the Javascript as well!
    const currentTier = "<%= account.account_tier || 'Basic' %>";
    const dailyLimit = <%= account.daily_limit || 10000 %>;
    let currentThemeColor = 'var(--primary)';

    function switchCurrency(type) {
      const tabs = document.querySelectorAll('.tab');
      const eurFields = document.getElementById('eur-fields');
      const cryptoFields = document.getElementById('crypto-fields');
      const cryptoLabel = document.getElementById('crypto-label');
      const sym = document.getElementById('currency-sym');
      const balDisplay = document.getElementById('balance-display');
      const limitDisplay = document.getElementById('limit-display');
      const btn = document.getElementById('submit-btn');
      const amountInput = document.querySelector('.amount-input');
      const currencyInput = document.getElementById('currency_type_input');

      tabs.forEach(t => t.classList.remove('active'));
      btn.className = 'btn-submit'; 
      currencyInput.value = type;

      if (type === 'eur') {
        document.querySelector('[data-currency="eur"]').classList.add('active');
        eurFields.style.display = 'block';
        cryptoFields.style.display = 'none';
        sym.innerText = '€';
        amountInput.placeholder = '0.00';
        balDisplay.innerText = `Available: €${fiatBal.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
        limitDisplay.style.display = 'block';
        amountInput.style.color = "var(--text-main)";
        currentThemeColor = 'var(--primary)';
        document.querySelector('input[name="recipient_name"]').required = true;
        document.querySelector('input[name="iban"]').required = true;
        document.querySelector('input[name="crypto_address"]').required = false;
      } 
      else if (type === 'btc') {
        document.querySelector('[data-currency="btc"]').classList.add('active');
        eurFields.style.display = 'none';
        cryptoFields.style.display = 'block';
        cryptoLabel.innerText = "Bitcoin Wallet Address";
        sym.innerText = '₿';
        amountInput.placeholder = '0.00000000';
        balDisplay.innerText = `Available: ${btcBal.toFixed(8)} BTC`;
        limitDisplay.style.display = 'none';
        btn.classList.add('btc-mode');
        amountInput.style.color = "var(--btc)";
        currentThemeColor = 'var(--btc)';
        document.querySelector('input[name="recipient_name"]').required = false;
        document.querySelector('input[name="iban"]').required = false;
        document.querySelector('input[name="crypto_address"]').required = true;
      }
      else if (type === 'eth') {
        document.querySelector('[data-currency="eth"]').classList.add('active');
        eurFields.style.display = 'none';
        cryptoFields.style.display = 'block';
        cryptoLabel.innerText = "Ethereum Wallet Address";
        sym.innerText = '⟠';
        amountInput.placeholder = '0.00000000';
        balDisplay.innerText = `Available: ${ethBal.toFixed(8)} ETH`;
        limitDisplay.style.display = 'none';
        btn.classList.add('eth-mode');
        amountInput.style.color = "var(--eth)";
        currentThemeColor = 'var(--eth)';
        document.querySelector('input[name="recipient_name"]').required = false;
        document.querySelector('input[name="iban"]').required = false;
        document.querySelector('input[name="crypto_address"]').required = true;
      }
    }

    function toggleSidebar() {
      document.querySelector('.sidebar').classList.toggle('open');
      document.querySelector('.sidebar-overlay').classList.toggle('open');
    }

    document.getElementById('sendForm').addEventListener('submit', function(e) {
      e.preventDefault(); 
      
      const overlay = document.getElementById('loadingOverlay');
      const subtext = document.getElementById('loadingSubtext');
      const spinner = document.getElementById('dynamicSpinner');
      
      spinner.style.borderTopColor = currentThemeColor;
      overlay.classList.add('active');

      const isCrypto = document.getElementById('currency_type_input').value !== 'eur';

      if(isCrypto) {
        setTimeout(() => subtext.innerText = "Estimating network gas fees...", 700);
        setTimeout(() => subtext.innerText = "Signing transaction payload...", 1800);
      } else {
        setTimeout(() => subtext.innerText = "Running AML/KYC fraud checks...", 700);
        setTimeout(() => subtext.innerText = "Connecting to SEPA routing gateway...", 1800);
      }
      
      setTimeout(() => {
        this.submit();
      }, 2800);
    });
  </script>
</body>
</html>