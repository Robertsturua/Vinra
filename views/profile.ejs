<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Venra Bank | Settings</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #4f46e5; --primary-hover: #4338ca; --bg-color: #f8fafc; --surface: #ffffff; --text-main: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --success: #10b981; --danger: #ef4444; --font: 'Inter', sans-serif; }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font); }
    body { background-color: var(--bg-color); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; }

    /* DARK SIDEBAR STYLES */
    .mobile-header { display: none; padding: 16px 20px; background: #0f172a; color: white; align-items: center; justify-content: space-between; }
    .mobile-header img { height: 35px; object-fit: contain; }
    .menu-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: white; }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); z-index: 99; backdrop-filter: blur(2px); }

    .sidebar { width: 260px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; display: flex; flex-direction: column; padding: 24px 20px; z-index: 100; box-shadow: 4px 0 15px rgba(0,0,0,0.05); }
    .brand { display: flex; align-items: center; justify-content: center; margin-bottom: 40px; padding: 0 10px; }
    .brand img { height: 75px; object-fit: contain; } 
    
    .nav-menu { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
    .nav-link.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3); }
    
    .user-profile { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary), #818cf8); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .user-info { display: flex; flex-direction: column; }
    .user-info span { font-size: 13px; font-weight: 700; color: white; }
    .user-info small { font-size: 11px; color: #94a3b8; }

    /* PAGE SPECIFIC STYLES */
    .main-content { flex: 1; overflow-y: auto; padding: 40px 60px; }
    .topbar { margin-bottom: 30px; }
    .topbar h1 { font-size: 28px; font-weight: 800; letter-spacing: -1px; }

    .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 1000px; align-items: start; }
    .card { background: var(--surface); border-radius: 24px; padding: 32px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-bottom: 24px; font-size: 16px; border-bottom: 1px solid var(--border); padding-bottom: 10px; color: var(--text-main); }

    .msg-alert { background: #dcfce7; color: #166534; padding: 14px 16px; border-radius: 12px; font-size: 14px; font-weight: 600; margin-bottom: 24px; border: 1px solid #bbf7d0; text-align: center; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .full-width { grid-column: 1 / -1; }
    .input-group label { display: block; font-size: 12px; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .input-group input { width: 100%; padding: 14px; border: 1px solid var(--border); border-radius: 12px; font-size: 14px; font-family: var(--font); background: #f8fafc; outline: none; transition: 0.2s; color: var(--text-main); }
    .input-group input:focus { border-color: var(--primary); background: #ffffff; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
    .input-group input[readonly] { color: var(--primary); cursor: not-allowed; font-weight: 700; background: #e0e7ff; border-color: #c7d2fe;}
    
    .btn-submit { width: 100%; padding: 14px; background: var(--primary); color: white; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; transition: 0.2s; margin-top: 10px; }
    .btn-submit:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3); }

    @media (max-width: 900px) {
      body { flex-direction: column; }
      .mobile-header { display: flex; }
      .sidebar { position: fixed; left: -100%; top: 0; bottom: 0; transition: left 0.3s ease; width: 280px; }
      .sidebar.open { left: 0; }
      .sidebar-overlay.open { display: block; }
      .main-content { padding: 20px; flex: 1; }
      .profile-grid { grid-template-columns: 1fr; }
      .form-grid { grid-template-columns: 1fr; }
      .card { padding: 24px; }
    }
  </style>
</head>
<body>

  <div class="mobile-header">
    <div style="display: flex; align-items: center; gap: 10px;">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
  </div>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

  <aside class="sidebar">
    <div class="brand">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <nav class="nav-menu">
      <a href="/dashboard" class="nav-link">Home</a>
      <a href="/send" class="nav-link">Send Money</a>
      <a href="/receive" class="nav-link">Receive Money</a>
      <a href="/transfers" class="nav-link">Transactions</a>
      <a href="/hisa" class="nav-link">Savings Account</a>
      <a href="/account" class="nav-link">Account Details</a>
      <a href="/support" class="nav-link">Support Hub</a>
      <a href="/profile" class="nav-link active">Settings</a>
    </nav>
    
    <div style="margin-top: auto;">
      <div class="user-profile">
        <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <div class="user-info"><span>@<%= user.username %></span><small><%= user.account.tier %> Plan</small></div>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="nav-link" style="width: 100%; background: transparent; border: none; cursor: pointer; color: #f87171; font-family: var(--font);">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-right: 12px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Log Out
        </button>
      </form>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar"><h1>Profile & Security</h1></div>

    <% if (msg) { %>
      <div class="msg-alert"><%= msg %></div>
    <% } %>

    <div class="profile-grid">
      <div class="card">
        <h3>Contact & Identity</h3>
        <form action="/profile" method="post">
          <div class="form-grid">
            <div class="input-group full-width">
              <label>Account ID</label>
              <input type="text" value="#<%= ((user.userId * 7391 + 482913) % 900000 + 100000) %>" readonly>
            </div>
            <div class="input-group full-width">
              <label>Full Name</label>
              <input type="text" name="full_name" value="<%= profile.full_name %>">
            </div>
            <div class="input-group">
              <label>Email Address</label>
              <input type="email" name="email" value="<%= profile.email %>">
            </div>
            <div class="input-group">
              <label>Phone Number</label>
              <input type="tel" name="phone" value="<%= profile.phone %>">
            </div>
            <div class="input-group full-width">
              <label>Street Address</label>
              <input type="text" name="street" value="<%= profile.street %>">
            </div>
            <div class="input-group">
              <label>City</label>
              <input type="text" name="city" value="<%= profile.city %>">
            </div>
            <div class="input-group">
              <label>State / Province</label>
              <input type="text" name="state" value="<%= profile.state %>">
            </div>
            <div class="input-group">
              <label>Postal / ZIP Code</label>
              <input type="text" name="postal_code" value="<%= profile.postal_code %>">
            </div>
            <div class="input-group full-width">
              <label>Country</label>
              <input type="text" name="country" value="<%= profile.country %>">
            </div>
          </div>
          <button type="submit" class="btn-submit">Update Information</button>
        </form>
      </div>

      <div class="card">
        <h3>Security</h3>
        <form action="/profile/password" method="post">
          <div class="input-group" style="margin-bottom: 16px;">
            <label>Current Password</label>
            <input type="password" name="current_password" required>
          </div>
          <div class="input-group" style="margin-bottom: 16px;">
            <label>New Password</label>
            <input type="password" name="new_password" required>
          </div>
          <div class="input-group" style="margin-bottom: 16px;">
            <label>Confirm New Password</label>
            <input type="password" name="confirm_password" required>
          </div>
          <button type="submit" class="btn-submit" style="background: #1e293b;">Change Password</button>
        </form>
      </div>

    </div>
  </main>

  <script>
    function toggleSidebar() {
      document.querySelector('.sidebar').classList.toggle('open');
      document.querySelector('.sidebar-overlay').classList.toggle('open');
    }
  </script>
</body>
</html>