<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Venra Bank | High-Interest Savings</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #4f46e5; --primary-hover: #4338ca; --bg-color: #f8fafc; --surface: #ffffff; --text-main: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --success: #10b981; --danger: #ef4444; --font: 'Inter', sans-serif; }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font); }
    body { background-color: var(--bg-color); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; }

    /* DARK SIDEBAR STYLES */
    .mobile-header { display: none; padding: 16px 20px; background: #0f172a; color: white; align-items: center; justify-content: space-between; }
    .mobile-header img { height: 35px; object-fit: contain; }
    .menu-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: white; }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); z-index: 99; backdrop-filter: blur(2px); }

    .sidebar { width: 260px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; display: flex; flex-direction: column; padding: 24px 20px; z-index: 100; box-shadow: 4px 0 15px rgba(0,0,0,0.05); }
    .brand { display: flex; align-items: center; justify-content: center; margin-bottom: 40px; padding: 0 10px; }
    .brand img { height: 75px; object-fit: contain; } 
    
    .nav-menu { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
    .nav-link.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3); }
    
    .user-profile { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary), #818cf8); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .user-info { display: flex; flex-direction: column; }
    .user-info span { font-size: 13px; font-weight: 700; color: white; }
    .user-info small { font-size: 11px; color: #94a3b8; }

    /* PAGE SPECIFIC STYLES */
    .main-content { flex: 1; overflow-y: auto; padding: 40px 60px; display: flex; flex-direction: column; align-items: center; }
    .topbar { width: 100%; max-width: 800px; margin-bottom: 30px; }
    .topbar h1 { font-size: 28px; font-weight: 800; letter-spacing: -1px; }

    .card { background: var(--surface); border-radius: 24px; padding: 40px; border: 1px solid var(--border); box-shadow: 0 4px 20px rgba(0,0,0,0.02); width: 100%; max-width: 800px; }
    
    .marketing-hero { text-align: center; padding: 20px 0; }
    .marketing-hero h2 { font-size: 36px; font-weight: 800; letter-spacing: -1px; margin-bottom: 16px; color: var(--primary); }
    .marketing-hero p { font-size: 16px; color: var(--text-muted); line-height: 1.6; margin-bottom: 32px; max-width: 600px; margin-left: auto; margin-right: auto; }
    
    .features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; text-align: left; margin-bottom: 40px; }
    .feature-box { background: #f8fafc; padding: 20px; border-radius: 16px; border: 1px solid var(--border); }
    .feature-box h4 { font-size: 16px; font-weight: 700; margin-bottom: 8px; color: var(--text-main); }
    .feature-box p { font-size: 14px; color: var(--text-muted); line-height: 1.5; margin: 0;}

    .review-hero { text-align: center; padding: 40px 20px; }
    .review-icon { font-size: 48px; margin-bottom: 20px; }
    .review-hero h2 { font-size: 28px; font-weight: 800; color: var(--text-main); margin-bottom: 16px; }
    .review-hero p { font-size: 15px; color: var(--text-muted); line-height: 1.6; max-width: 500px; margin: 0 auto 24px auto; }
    .review-box { background: #eff6ff; border: 1px solid #bfdbfe; padding: 20px; border-radius: 16px; display: inline-block; text-align: left; }

    .hisa-dashboard { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
    .balance-card { background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 32px; border-radius: 20px; color: white; box-shadow: 0 10px 20px -5px rgba(16, 185, 129, 0.4); }
    .balance-label { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; opacity: 0.9; margin-bottom: 8px; }
    .balance-amount { font-size: 48px; font-weight: 800; letter-spacing: -1px; word-break: break-all; }
    .apr-badge { display: inline-block; background: rgba(255,255,255,0.2); padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 700; margin-top: 16px; backdrop-filter: blur(4px); }

    .transfer-form { background: #f8fafc; padding: 24px; border-radius: 20px; border: 1px solid var(--border); }
    .transfer-form h3 { font-size: 18px; font-weight: 700; margin-bottom: 20px; }
    
    .input-group { margin-bottom: 20px; }
    .input-group label { display: block; font-size: 13px; font-weight: 600; color: var(--text-main); margin-bottom: 8px; }
    .input-group select, .input-group input { width: 100%; padding: 14px; border: 1px solid var(--border); border-radius: 12px; font-size: 15px; font-family: var(--font); background: #ffffff; transition: all 0.2s; outline: none; }
    .input-group select:focus, .input-group input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }

    .btn-submit { width: 100%; padding: 16px; background: var(--primary); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-submit:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3); }
    .btn-activate { background: #10b981; font-size: 18px; padding: 20px 40px; max-width: 300px; margin: 0 auto; display: block; }
    .btn-activate:hover { background: #059669; box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4); }

    @media (max-width: 900px) {
      body { flex-direction: column; }
      .mobile-header { display: flex; }
      .sidebar { position: fixed; left: -100%; top: 0; bottom: 0; transition: left 0.3s ease; width: 280px; }
      .sidebar.open { left: 0; }
      .sidebar-overlay.open { display: block; }
      .main-content { padding: 20px; flex: 1; align-items: stretch; }
      .card { padding: 24px; max-width: 100%; }
      .hisa-dashboard { grid-template-columns: 1fr; }
      .features-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <div class="mobile-header">
    <div style="display: flex; align-items: center; gap: 10px;">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
  </div>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

  <aside class="sidebar">
    <div class="brand">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <nav class="nav-menu">
      <a href="/dashboard" class="nav-link">Home</a>
      <a href="/send" class="nav-link">Send Money</a>
      <a href="/receive" class="nav-link">Receive Money</a>
      <a href="/transfers" class="nav-link">Transactions</a>
      <a href="/hisa" class="nav-link active">Savings Account</a>
      <a href="/account" class="nav-link">Account Details</a>
      <a href="/support" class="nav-link">Support Hub</a>
      <a href="/profile" class="nav-link">Settings</a>
    </nav>
    
    <div style="margin-top: auto;">
      <div class="user-profile">
        <div class="avatar"><%= username.charAt(0).toUpperCase() %></div>
        <div class="user-info"><span>@<%= username %></span><small><%= account.tier %> Plan</small></div>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="nav-link" style="width: 100%; background: transparent; border: none; cursor: pointer; color: #f87171; font-family: var(--font);">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-right: 12px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Log Out
        </button>
      </form>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar"><h1>High-Interest Savings</h1></div>

    <div class="card">
      <% if (account.hisa_status === 'INACTIVE') { %>
        <div class="marketing-hero">
          <h2>Make your money work harder.</h2>
          <p>Open a High-Interest Savings Account (HISA) today and start earning an industry-leading Annual Percentage Yield on your idle EUR balance.</p>
          
          <div class="features-grid">
            <div class="feature-box">
              <h4>📈 9.5% Standard APY</h4>
              <p>Earn high yields paid out monthly, directly into your savings account. Watch your wealth compound automatically.</p>
            </div>
            <div class="feature-box">
              <h4>⚡ Instant Transfers</h4>
              <p>Move money instantly between your Main EUR account and your HISA. No locking periods, no waiting days.</p>
            </div>
            <div class="feature-box">
              <h4>🔒 Capital Protection</h4>
              <p>Your HISA balance is stored in secure, offline environments to ensure maximum protection of your principal.</p>
            </div>
            <div class="feature-box">
              <h4>⭐ Premium Upgrades</h4>
              <p>Once active, eligible accounts can upgrade to our Premium HISA tier to unlock an exclusive 12.5% APY.</p>
            </div>
          </div>

          <% if (userStatus === 'ACTIVE') { %>
            <form action="/hisa/activate" method="POST">
              <button type="submit" class="btn-submit btn-activate">Open Savings Account</button>
            </form>
          <% } else { %>
            <div style="text-align: center; color: var(--danger); font-weight: 600;">⚠️ You must fully verify your main account before applying for a HISA.</div>
          <% } %>
        </div>

      <% } else if (account.hisa_status === 'PENDING') { %>
        <div class="review-hero">
          <div class="review-icon">📋</div>
          <h2>Application Under Review</h2>
          <p>Your request to open a High-Interest Savings Account has been successfully submitted to our compliance and wealth management division.</p>
          
          <div class="review-box">
            <h4 style="color: #1e3a8a; font-size: 14px; margin-bottom: 8px;">What happens next?</h4>
            <p style="font-size: 13px; color: #3b82f6; margin: 0; line-height: 1.5;">An account representative is reviewing your financial profile to ensure eligibility. Once approved, your HISA dashboard will automatically unlock here. If we require further documentation, support will contact you.</p>
          </div>
        </div>

      <% } else { %>
        <% if (userStatus === 'SUSPENDED') { %>
          <div style="background: #fee2e2; color: #991b1b; padding: 16px; border-radius: 12px; margin-bottom: 24px; text-align: center; font-size: 14px; font-weight: 600; border: 1px solid #fca5a5;">
            ⚠️ Your account is under review. Internal transfers are temporarily disabled.
          </div>
        <% } %>

        <div class="hisa-dashboard">
          <div>
            <% if (account.hisa_tier === 'Premium') { %>
              <div class="balance-card" style="background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%); box-shadow: 0 10px 20px -5px rgba(245, 158, 11, 0.4);">
                <div class="balance-label" style="color: #78350f;">Premium Savings Balance</div>
                <div class="balance-amount" style="color: #451a03;">€<%= hisaBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) %></div>
                <div class="apr-badge" style="background: #fffbeb; color: #b45309;">Current Yield: 12.5% APY</div>
              </div>
            <% } else { %>
              <div class="balance-card">
                <div class="balance-label">Total Savings Balance</div>
                <div class="balance-amount">€<%= hisaBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) %></div>
                <div class="apr-badge">Current Yield: 9.5% APY</div>
              </div>
            <% } %>
            
            <% if (account.hisa_tier !== 'Premium') { %>
              <div style="margin-top: 24px; padding: 20px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 16px;">
                <h4 style="color: #1e3a8a; font-size: 15px; margin-bottom: 8px;">Upgrade to Premium</h4>
                <p style="font-size: 13px; color: #3b82f6; margin-bottom: 16px;">Boost your earnings to an exclusive 12.5% APY. Contact your account manager to check eligibility.</p>
                <a href="/support" style="background: #2563eb; color: white; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; display: inline-block;">Contact Support</a>
              </div>
            <% } else { %>
              <div style="margin-top: 24px; padding: 20px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 16px;">
                <h4 style="color: #92400e; font-size: 15px; margin-bottom: 8px;">Premium Active 👑</h4>
                <p style="font-size: 13px; color: #b45309; margin-bottom: 0;">You are currently earning the maximum tier APY. Interest is calculated daily and paid monthly.</p>
              </div>
            <% } %>
          </div>

          <div class="transfer-form">
            <h3>Internal Transfer</h3>
            <form action="/transfer/internal" method="POST">
              <div class="input-group">
                <label>Transfer Route</label>
                <select name="direction" id="routeSelect" onchange="updateRoute()" <%= userStatus === 'SUSPENDED' ? 'disabled' : '' %>>
                  <option value="to_hisa">Main Account ➔ Savings Account</option>
                  <option value="to_main">Savings Account ➔ Main Account</option>
                </select>
              </div>
              <input type="hidden" name="from_account" id="from_account" value="main">
              <input type="hidden" name="to_account" id="to_account" value="hisa">

              <div class="input-group">
                <label>Amount (€)</label>
                <input type="number" step="any" name="amount" placeholder="0.00" required <%= userStatus === 'SUSPENDED' ? 'disabled' : '' %>>
                <div style="font-size: 12px; color: var(--text-muted); margin-top: 8px; text-align: right;" id="availableText">
                  Available in Main: €<%= fiatBalance.toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                </div>
              </div>

              <button type="submit" class="btn-submit" <%= userStatus === 'SUSPENDED' ? 'disabled style="opacity:0.5;"' : '' %>>Confirm Transfer</button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </main>

  <script>
    const fiatBal = <%= fiatBalance %>;
    const hisaBal = <%= hisaBalance %>;

    function updateRoute() {
      const route = document.getElementById('routeSelect').value;
      const from = document.getElementById('from_account');
      const to = document.getElementById('to_account');
      const avail = document.getElementById('availableText');

      if (route === 'to_hisa') {
        from.value = 'main';
        to.value = 'hisa';
        avail.innerText = `Available in Main: €${fiatBal.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
      } else {
        from.value = 'hisa';
        to.value = 'main';
        avail.innerText = `Available in Savings: €${hisaBal.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
      }
    }

    function toggleSidebar() {
      document.querySelector('.sidebar').classList.toggle('open');
      document.querySelector('.sidebar-overlay').classList.toggle('open');
    }
  </script>
</body>
</html>