<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Venra Bank | Transactions</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #4f46e5; --primary-hover: #4338ca; --bg-color: #f8fafc; --surface: #ffffff; --text-main: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --success: #10b981; --danger: #ef4444; --font: 'Inter', sans-serif; }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font); }
    body { background-color: var(--bg-color); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; }

    /* DARK SIDEBAR STYLES */
    .mobile-header { display: none; padding: 16px 20px; background: #0f172a; color: white; align-items: center; justify-content: space-between; }
    .mobile-header img { height: 35px; object-fit: contain; }
    .menu-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: white; }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); z-index: 99; backdrop-filter: blur(2px); }

    .sidebar { width: 260px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; display: flex; flex-direction: column; padding: 24px 20px; z-index: 100; box-shadow: 4px 0 15px rgba(0,0,0,0.05); }
    .brand { display: flex; align-items: center; justify-content: center; margin-bottom: 40px; padding: 0 10px; }
    .brand img { height: 75px; object-fit: contain; } 
    
    .nav-menu { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
    .nav-link.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3); }
    
    .user-profile { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary), #818cf8); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .user-info { display: flex; flex-direction: column; }
    .user-info span { font-size: 13px; font-weight: 700; color: white; }
    .user-info small { font-size: 11px; color: #94a3b8; }

    /* PAGE SPECIFIC STYLES */
    .main-content { flex: 1; overflow-y: auto; padding: 40px 60px; }
    .topbar { margin-bottom: 30px; }
    .topbar h1 { font-size: 28px; font-weight: 800; letter-spacing: -1px; }

    .card { background: var(--surface); border-radius: 24px; padding: 32px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); max-width: 900px; }
    
    .filter-tabs { display: flex; gap: 12px; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 16px; overflow-x: auto; }
    .filter-btn { background: none; border: none; font-size: 14px; font-weight: 600; color: var(--text-muted); cursor: pointer; padding: 8px 16px; border-radius: 20px; transition: all 0.2s; white-space: nowrap; }
    .filter-btn:hover { background: #f1f5f9; color: var(--text-main); }
    .filter-btn.active { background: var(--primary); color: white; box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2); }

    .tx-list { display: flex; flex-direction: column; gap: 12px; }
    .tx-item { display: flex; justify-content: space-between; align-items: center; padding: 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; transition: all 0.2s; }
    .tx-item:hover { transform: translateX(4px); border-color: #cbd5e1; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
    .tx-left { display: flex; align-items: center; gap: 16px; }
    .tx-icon { width: 48px; height: 48px; background: #f1f5f9; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;}
    .tx-details h4 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
    .tx-details p { font-size: 13px; color: var(--text-muted); font-family: monospace; }
    .tx-right { text-align: right; }
    
    .tx-amount { font-size: 16px; font-weight: 800; margin-bottom: 6px; transition: color 0.3s; }
    .tx-amount.amt-pending { color: #a16207; } 
    .tx-amount.amt-declined { color: #64748b; text-decoration: line-through; opacity: 0.6; } 
    .tx-amount.amt-completed.incoming { color: #15803d; } 
    .tx-amount.amt-completed.outgoing { color: var(--text-main); }
    
    .tx-status { font-size: 11px; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; }
    .status-completed { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    .status-pending { background: #fef08a; color: #a16207; border: 1px solid #fde047; }
    .status-declined { background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1; }

    .empty-state { text-align: center; padding: 40px; color: var(--text-muted); font-size: 15px; font-weight: 500; display: none; }

    @media (max-width: 900px) {
      body { flex-direction: column; }
      .mobile-header { display: flex; }
      .sidebar { position: fixed; left: -100%; top: 0; bottom: 0; transition: left 0.3s ease; width: 280px; }
      .sidebar.open { left: 0; }
      .sidebar-overlay.open { display: block; }
      .main-content { padding: 20px; flex: 1; }
      .card { padding: 20px; }
      .tx-item { flex-direction: column; align-items: flex-start; gap: 12px; }
      .tx-right { text-align: left; width: 100%; display: flex; justify-content: space-between; align-items: center; }
    }
  </style>
</head>
<body>

  <div class="mobile-header">
    <div style="display: flex; align-items: center; gap: 10px;">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
  </div>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

  <aside class="sidebar">
    <div class="brand">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <nav class="nav-menu">
      <a href="/dashboard" class="nav-link">Home</a>
      <a href="/send" class="nav-link">Send Money</a>
      <a href="/receive" class="nav-link">Receive Money</a>
      <a href="/transfers" class="nav-link active">Transactions</a>
      <a href="/hisa" class="nav-link">Savings Account</a>
      <a href="/account" class="nav-link">Account Details</a>
      <a href="/support" class="nav-link">Support Hub</a>
      <a href="/profile" class="nav-link">Settings</a>
    </nav>
    
    <div style="margin-top: auto;">
      <div class="user-profile">
        <div class="avatar"><%= username.charAt(0).toUpperCase() %></div>
        <div class="user-info"><span>@<%= username %></span><small><%= account.tier %> Plan</small></div>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="nav-link" style="width: 100%; background: transparent; border: none; cursor: pointer; color: #f87171; font-family: var(--font);">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-right: 12px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Log Out
        </button>
      </form>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar"><h1>Transaction History</h1></div>
    <div class="card">
      
      <div class="filter-tabs">
        <button class="filter-btn active" onclick="filterTx('ALL', this)">All</button>
        <button class="filter-btn" onclick="filterTx('INCOMING', this)">Incoming</button>
        <button class="filter-btn" onclick="filterTx('OUTGOING', this)">Outgoing</button>
      </div>

      <div class="tx-list" id="tx-container">
        
        <div id="empty-all" class="empty-state" style="<%= transactions.length === 0 ? 'display: block;' : '' %>">Your transaction history is currently empty.</div>
        <div id="empty-in" class="empty-state">You have no incoming transactions.</div>
        <div id="empty-out" class="empty-state">You have no outgoing transfers.</div>

        <% transactions.forEach(tx => { %>
          <div class="tx-item" data-direction="<%= tx.direction %>">
            <div class="tx-left">
              <div class="tx-icon"><%= tx.icon %></div>
              <div class="tx-details">
                <h4><%= tx.name %></h4>
                <p><%= tx.date %> • <%= tx.detail %></p>
              </div>
            </div>
            <div class="tx-right">
              <div class="tx-amount amt-<%= tx.status.toLowerCase() %> <%= tx.direction.toLowerCase() %>">
                <%= tx.direction === 'INCOMING' ? '+' : '-' %><%= tx.amountStr %>
              </div>
              <div class="tx-status status-<%= tx.status.toLowerCase() %>"><%= tx.status %></div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <script>
    function toggleSidebar() {
      document.querySelector('.sidebar').classList.toggle('open');
      document.querySelector('.sidebar-overlay').classList.toggle('open');
    }

    function filterTx(type, btnElement) {
      document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
      btnElement.classList.add('active');

      const items = document.querySelectorAll('.tx-item');
      let visibleCount = 0;

      items.forEach(item => {
        if (type === 'ALL' || item.dataset.direction === type) {
          item.style.display = 'flex';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      document.getElementById('empty-all').style.display = 'none';
      document.getElementById('empty-in').style.display = 'none';
      document.getElementById('empty-out').style.display = 'none';

      if (visibleCount === 0) {
        if (type === 'ALL') document.getElementById('empty-all').style.display = 'block';
        if (type === 'INCOMING') document.getElementById('empty-in').style.display = 'block';
        if (type === 'OUTGOING') document.getElementById('empty-out').style.display = 'block';
      }
    }
  </script>
</body>
</html>