<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Venra Bank | Account Details</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #4f46e5; --primary-hover: #4338ca; --bg-color: #f8fafc; --surface: #ffffff; --text-main: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --danger: #ef4444; --font: 'Inter', sans-serif; }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font); }
    body { background-color: var(--bg-color); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; }

    /* DARK SIDEBAR STYLES */
    .mobile-header { display: none; padding: 16px 20px; background: #0f172a; color: white; align-items: center; justify-content: space-between; }
    .mobile-header img { height: 35px; object-fit: contain; }
    .menu-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: white; }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); z-index: 99; backdrop-filter: blur(2px); }

    .sidebar { width: 260px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; display: flex; flex-direction: column; padding: 24px 20px; z-index: 100; box-shadow: 4px 0 15px rgba(0,0,0,0.05); }
    .brand { display: flex; align-items: center; justify-content: center; margin-bottom: 40px; padding: 0 10px; }
    .brand img { height: 75px; object-fit: contain; } 
    
    .nav-menu { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
    .nav-link.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3); }
    
    .user-profile { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(0,0,0,0.2); border-radius: 12px; margin-bottom: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary), #818cf8); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .user-info { display: flex; flex-direction: column; }
    .user-info span { font-size: 13px; font-weight: 700; color: white; }
    .user-info small { font-size: 11px; color: #94a3b8; }

    /* PAGE SPECIFIC STYLES */
    .main-content { flex: 1; overflow-y: auto; padding: 40px 60px; }
    .topbar { margin-bottom: 30px; }
    .topbar h1 { font-size: 28px; font-weight: 800; letter-spacing: -1px; }

    .grid-layout { display: grid; grid-template-columns: 1.2fr 1fr; gap: 32px; max-width: 1200px;}
    
    .virtual-card { background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); border-radius: 24px; padding: 32px; color: white; position: relative; overflow: hidden; box-shadow: 0 10px 30px rgba(49, 46, 129, 0.2); }
    .virtual-card::after { content: ''; position: absolute; width: 400px; height: 400px; background: rgba(255,255,255,0.03); border-radius: 50%; top: -100px; right: -100px; pointer-events: none; }
    .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; position: relative; z-index: 10; }
    .card-logo { font-size: 20px; font-weight: 800; font-style: italic; letter-spacing: 1px; }
    .card-tier-badge { font-weight: 600; font-size: 13px; background: rgba(255,255,255,0.15); padding: 4px 12px; border-radius: 20px; backdrop-filter: blur(4px); }
    
    .card-data-row { display: flex; flex-direction: column; margin-bottom: 20px; position: relative; z-index: 10; }
    .card-data-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #a5b4fc; margin-bottom: 4px; font-weight: 600; }
    .card-data-value { font-size: 16px; font-family: monospace; font-weight: 600; letter-spacing: 1px; display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 12px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); }
    .btn-copy-icon { background: none; border: none; color: #a5b4fc; cursor: pointer; transition: 0.2s; padding: 4px; border-radius: 4px; font-size: 14px; font-family: var(--font); font-weight: 700; }
    .btn-copy-icon:hover { color: white; background: rgba(255,255,255,0.1); }

    .tiers-box { background: var(--surface); border-radius: 24px; padding: 32px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
    .tiers-box h3 { margin-bottom: 8px; font-size: 18px; font-weight: 700; }
    .tiers-box > p { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; line-height: 1.5; }

    .tier-item { display: flex; justify-content: space-between; align-items: center; padding: 16px; border: 1px solid var(--border); border-radius: 16px; margin-bottom: 12px; transition: 0.2s; }
    .tier-item.active { background: #f8fafc; border-color: var(--primary); box-shadow: 0 0 0 1px var(--primary); }
    .tier-info h4 { font-size: 15px; font-weight: 700; margin-bottom: 4px; color: var(--text-main); }
    .tier-info p { font-size: 13px; color: var(--text-muted); }
    
    .btn-activate { background: var(--surface); border: 1px solid var(--primary); color: var(--primary); font-weight: 600; padding: 8px 16px; border-radius: 8px; font-size: 13px; cursor: pointer; transition: 0.2s; }
    .btn-activate:hover { background: var(--primary); color: white; }
    .badge-current { background: var(--primary); color: white; font-weight: 700; padding: 6px 12px; border-radius: 8px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }

    .review-hero { text-align: center; padding: 30px 20px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 16px; }
    .review-hero h2 { font-size: 20px; font-weight: 800; color: #1e3a8a; margin-bottom: 12px; }
    .review-hero p { font-size: 14px; color: #3b82f6; line-height: 1.6; margin: 0 auto; }

    @media (max-width: 900px) {
      body { flex-direction: column; }
      .mobile-header { display: flex; }
      .sidebar { position: fixed; left: -100%; top: 0; bottom: 0; transition: left 0.3s ease; width: 280px; }
      .sidebar.open { left: 0; }
      .sidebar-overlay.open { display: block; }
      .main-content { padding: 20px; flex: 1; }
      .grid-layout { grid-template-columns: 1fr; }
      .virtual-card { padding: 24px; }
    }
  </style>
</head>
<body>

  <div class="mobile-header">
    <div style="display: flex; align-items: center; gap: 10px;">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
  </div>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

  <aside class="sidebar">
    <div class="brand">
      <img src="/logo.png" alt="Venra Bank">
    </div>
    <nav class="nav-menu">
      <a href="/dashboard" class="nav-link">Home</a>
      <a href="/send" class="nav-link">Send Money</a>
      <a href="/receive" class="nav-link">Receive Money</a>
      <a href="/transfers" class="nav-link">Transactions</a>
      <a href="/hisa" class="nav-link">Savings Account</a>
      <a href="/account" class="nav-link active">Account Details</a>
      <a href="/support" class="nav-link">Support Hub</a>
      <a href="/profile" class="nav-link">Settings</a>
    </nav>
    
    <div style="margin-top: auto;">
      <div class="user-profile">
        <div class="avatar"><%= username.charAt(0).toUpperCase() %></div>
        <div class="user-info"><span>@<%= username %></span><small><%= account.tier %> Plan</small></div>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="nav-link" style="width: 100%; background: transparent; border: none; cursor: pointer; color: #f87171; font-family: var(--font);">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-right: 12px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Log Out
        </button>
      </form>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar"><h1>Account Details</h1></div>
    
    <div class="grid-layout">
      <div class="virtual-card">
        <div class="card-top">
          <div class="card-logo">VENRA</div>
          <div class="card-tier-badge"><%= account.account_tier %> EUR Account</div>
        </div>

        <div class="card-data-row">
          <div class="card-data-label">Beneficiary Name</div>
          <div class="card-data-value">
            <span class="copyable-text" style="font-family: var(--font);"><%= account.name %></span>
            <button class="btn-copy-icon">Copy</button>
          </div>
        </div>

        <div class="card-data-row">
          <div class="card-data-label">IBAN</div>
          <div class="card-data-value">
            <span class="copyable-text" style="<%= userStatus === 'PENDING' ? 'color: #fde047; font-family: var(--font);' : '' %>">
              <%= userStatus === 'PENDING' ? 'Pending verification' : account.iban %>
            </span>
            <% if (userStatus !== 'PENDING') { %><button class="btn-copy-icon">Copy</button><% } %>
          </div>
        </div>

        <div class="card-data-row" style="margin-bottom: 0;">
          <div class="card-data-label">BIC / SWIFT</div>
          <div class="card-data-value">
            <span class="copyable-text" style="<%= userStatus === 'PENDING' ? 'color: #fde047; font-family: var(--font);' : '' %>">
              <%= userStatus === 'PENDING' ? 'Pending verification' : account.swift %>
            </span>
            <% if (userStatus !== 'PENDING') { %><button class="btn-copy-icon">Copy</button><% } %>
          </div>
        </div>
      </div>

      <div class="tiers-box">
        <h3>Account Tiers & Limits</h3>
        <p>To activate a larger daily transfer limit, select a plan below. To activate a larger transfer limit, our support team will need to verify your request.</p>
        
        <% if (account.tier_status === 'PENDING') { %>
          <div class="review-hero">
            <h2>Application Under Review</h2>
            <p>Your request to increase limits to the <strong><%= account.requested_tier %> Plan</strong> has been successfully submitted. Our support team will contact you shortly.</p>
          </div>
        <% } else { %>
          
          <div class="tier-item <%= account.account_tier === 'Basic' ? 'active' : '' %>">
            <div class="tier-info"><h4>Basic Plan</h4><p>Daily limit: €10,000</p></div>
            <% if(account.account_tier === 'Basic') { %><span class="badge-current">Current</span>
            <% } else { %><form action="/account/upgrade" method="POST"><input type="hidden" name="tier" value="Basic"><button class="btn-activate">Activate</button></form><% } %>
          </div>

          <div class="tier-item <%= account.account_tier === 'Standard' ? 'active' : '' %>">
            <div class="tier-info"><h4>Standard Plan</h4><p>Daily limit: €50,000</p></div>
            <% if(account.account_tier === 'Standard') { %><span class="badge-current">Current</span>
            <% } else { %><form action="/account/upgrade" method="POST"><input type="hidden" name="tier" value="Standard"><button class="btn-activate">Activate</button></form><% } %>
          </div>

          <div class="tier-item <%= account.account_tier === 'Premium' ? 'active' : '' %>">
            <div class="tier-info"><h4>Premium Plan</h4><p>Daily limit: €100,000</p></div>
            <% if(account.account_tier === 'Premium') { %><span class="badge-current">Current</span>
            <% } else { %><form action="/account/upgrade" method="POST"><input type="hidden" name="tier" value="Premium"><button class="btn-activate">Activate</button></form><% } %>
          </div>

          <div class="tier-item <%= account.account_tier === 'VIP' ? 'active' : '' %>">
            <div class="tier-info"><h4>VIP Plan</h4><p>Daily limit: €250,000</p></div>
            <% if(account.account_tier === 'VIP') { %><span class="badge-current">Current</span>
            <% } else { %><form action="/account/upgrade" method="POST"><input type="hidden" name="tier" value="VIP"><button class="btn-activate">Activate</button></form><% } %>
          </div>

        <% } %>
      </div>
    </div>
  </main>

  <script>
    function toggleSidebar() {
      document.querySelector('.sidebar').classList.toggle('open');
      document.querySelector('.sidebar-overlay').classList.toggle('open');
    }

    document.querySelectorAll('.btn-copy-icon').forEach(button => {
      button.addEventListener('click', async function() {
        const valueSpan = this.previousElementSibling;
        if (!valueSpan) return;
        const textToCopy = valueSpan.innerText;
        try {
          await navigator.clipboard.writeText(textToCopy);
          const originalText = this.innerText;
          this.innerText = 'Copied';
          this.style.color = '#10b981';
          setTimeout(() => { this.innerText = originalText; this.style.color = '#a5b4fc'; }, 2000);
        } catch (err) {
          console.error('Failed to copy: ', err);
          this.innerText = 'Failed';
        }
      });
    });
  </script>
</body>
</html>